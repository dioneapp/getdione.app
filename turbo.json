{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "preview": {
      "dependsOn": ["build"]
    },
    "deploy": {
      "dependsOn": ["build"]
    }
  },
  "globalEnv": [
    "BETA_DISCORD_WEBHOOK_URL",
    "FEATURED_DISCORD_WEBHOOK_URL",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_KEY",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "NEXT_PUBLIC_DATABUDDY_CLIENT_ID",
    "GITHUB_TOKEN",
    "NODE_ENV"
  ]
}